# Copy this file to .env and fill in your key before starting the server.

# OpenAI API key — used by the chat agent model (gpt-4o-mini by default).
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Swap provider ──────────────────────────────────────────────────────────────
# Eidentic uses the Vercel AI SDK, so any @ai-sdk/* provider works.
# Example: switch to Anthropic Claude
#   1. npm install @ai-sdk/anthropic
#   2. In server/index.ts replace:
#        import { openai } from "@ai-sdk/openai";
#        model: new AIModel(openai("gpt-4o-mini"))
#      with:
#        import { anthropic } from "@ai-sdk/anthropic";
#        model: new AIModel(anthropic("claude-3-5-haiku-20241022"))
#   3. Set ANTHROPIC_API_KEY instead of OPENAI_API_KEY
